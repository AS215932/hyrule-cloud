# Hyrule Cloud Configuration
# Copy to .env and fill in your values

# --- Xen Orchestra (all XCP-NG ops go through XO) ---
XCPNG_XO_URL=ws://[2a0c:b641:b50:2::70]/api/
XCPNG_XO_TOKEN=                  # Xen Orchestra -> Settings -> Tokens
XCPNG_XO_VERIFY_SSL=false
XCPNG_DEFAULT_SR_UUID=           # `xe sr-list` on your XCP-NG host
XCPNG_DEFAULT_NETWORK_UUID=      # `xe network-list` - your IPv6 network

# Template UUIDs: get with `xe template-list`
# Format: JSON dict {"debian-13": "uuid-here", "openbsd-7.8": "uuid-here"}
XCPNG_TEMPLATES={"debian-13": "", "openbsd-7.8": ""}

# OpenBSD offline root resize builder. Required for OpenBSD customer VMs.
# The builder is a dedicated OpenBSD VM that stays halted except while preparing
# a newly cloned OpenBSD root VDI before first boot.
XCPNG_OPENBSD_BUILDER_VM_UUID=
XCPNG_OPENBSD_BUILDER_SSH_HOST=
XCPNG_OPENBSD_BUILDER_SSH_USER=svag
XCPNG_OPENBSD_BUILDER_SSH_KEY_PATH=/run/secrets/openbsd_builder_ssh_key
XCPNG_OPENBSD_BUILDER_DISK_DEVICE=sd1
XCPNG_OPENBSD_BUILDER_ATTACH_POSITION=1

# --- Openprovider ---
OPENPROVIDER_API_URL=https://api.openprovider.eu/v1beta
OPENPROVIDER_USERNAME=
OPENPROVIDER_PASSWORD=
OPENPROVIDER_OWNER_HANDLE=       # e.g. SR003891-NL
OPENPROVIDER_ADMIN_HANDLE=
OPENPROVIDER_TECH_HANDLE=
OPENPROVIDER_BILLING_HANDLE=
OPENPROVIDER_NAMESERVERS=["ns1.servify.network","ns2.servify.network"]

# --- x402 Payments ---
PAYMENT_RECEIVER_ADDRESS=        # Your wallet address (receives USDC)
PAYMENT_FACILITATOR_URL=https://x402.org/facilitator
PAYMENT_NETWORK=eip155:8453      # Base mainnet
PAYMENT_ASSET=USDC

# Pricing (USD per day)
PAYMENT_PRICE_VM_XS=0.05
PAYMENT_PRICE_VM_SM=0.10
PAYMENT_PRICE_VM_MD=0.20
PAYMENT_PRICE_VM_LG=0.40
PAYMENT_PRICE_VPN=0.02
PAYMENT_PRICE_DOMAIN_MARKUP=1.00
PAYMENT_PRICE_PROXY_DIRECT=0.01
PAYMENT_PRICE_PROXY_TOR=0.05
PAYMENT_PRICE_PROXY_I2P=0.05
PAYMENT_PRICE_PROXY_YGGDRASIL=0.03
PAYMENT_PRICE_BGP_LOOKUP=0.005
PAYMENT_PRICE_BGP_ROUTER_QUERY=0.01
PAYMENT_PRICE_BGPSTREAM_HOUR=0.05
PAYMENT_PRICE_BGPSTREAM_RIB=0.10
PAYMENT_PRICE_BGP_ROUTER_TABLE=0.10
PAYMENT_PRICE_BGP_ROUTER_TABLE_ALL=0.25
PAYMENT_PRICE_IP_LOOKUP=0.003
PAYMENT_PRICE_DNS_LOOKUP=0.001
PAYMENT_PRICE_RDAP_LOOKUP=0.003
PAYMENT_PRICE_WHOIS_LOOKUP=0.005
PAYMENT_PRICE_MX_CHECK=0.005
PAYMENT_PRICE_MX_REPORT=0.03
PAYMENT_PRICE_WEB_CHECK=0.005
PAYMENT_PRICE_WEB_REPORT=0.03
PAYMENT_PRICE_WEB_TLS_DEEP=0.10
PAYMENT_PRICE_PATH_PROBE=0.005
PAYMENT_PRICE_PATH_REPORT=0.05
PAYMENT_PRICE_PORT_CHECK=0.003
PAYMENT_PRICE_NAT_LOOKUP=0.003
PAYMENT_PRICE_NAT_PORT_FORWARD_CHECK=0.005
PAYMENT_PRICE_THREAT_LOOKUP=0.01
PAYMENT_PRICE_VOIP_CHECK=0.01
PAYMENT_PRICE_VOIP_NUMBER_LOOKUP=0.05
PAYMENT_PRICE_VOIP_REPORT=0.08
PAYMENT_PRICE_SPEEDTEST=0.10
PAYMENT_PRICE_MAIL_AGENT_BASIC_DAY=0.05
PAYMENT_PRICE_MAIL_STORAGE_GB_DAY=0.01
PAYMENT_PRICE_MAIL_OUTBOUND_MESSAGE=0.001

# --- Hyrule General ---
HYRULE_DEPLOY_DOMAIN=deploy.hyrule.host

# Internal Go sidecar for x402-gated network requests.
HYRULE_NETWORK_PROXY_URL=http://127.0.0.1:8450
HYRULE_NETWORK_PROXY_TOKEN=
HYRULE_NETWORK_PROXY_HEALTH_TTL_SECONDS=15
HYRULE_BGP_DATA_ENABLED=true
HYRULE_BGP_DATA_DIR=/var/lib/hyrule-cloud/bgp
HYRULE_BGP_INGEST_TOKEN=

# DNS (RFC 2136 dynamic updates)
HYRULE_DNS_SERVER=              # Your authoritative NS IP
HYRULE_DNS_TSIG_KEY=            # Base64 TSIG key
HYRULE_DNS_TSIG_ALGO=hmac-sha256

# VM Lifecycle
HYRULE_VM_GRACE_PERIOD_HOURS=48
HYRULE_MAX_DURATION_DAYS=365
HYRULE_MAX_PORTS=10
HYRULE_BLOCKED_PORTS=[25,465,587]

# Database (Postgres)
HYRULE_DATABASE_URL=postgresql+asyncpg://hyrule:hyrule@localhost/hyrule

# --- Block A1 / B (Wave 2): auth + metrics ---

# 16+ byte hex used to derive the per-IP prefix hash for rate-limit
# buckets. If blank, sessions still work but per-IP pepper is
# process-local and rotates on every restart. Vault populates in
# production; set with `openssl rand -hex 16`.
HYRULE_IP_PREFIX_PEPPER=

# Feature flags — Wave 2 ships migration 004 (intent engine) as DEAD
# SCHEMA so the linear alembic chain stays intact, but the consumer
# code stays disabled until the relevant wave ships:
#   HYR_FEATURES_API_KEYS         — flipped on by Wave 3 (Block D)
#   HYR_FEATURES_INTENT_ENGINE    — flipped on by Wave 4 (Block E)
#   HYR_FEATURES_WALLET_RECOVERY  — flipped on by Wave 5 (Block F)
HYRULE_FEATURES_API_KEYS=false
HYRULE_FEATURES_INTENT_ENGINE=false
HYRULE_FEATURES_WALLET_RECOVERY=false
