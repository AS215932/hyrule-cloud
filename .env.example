# Hyrule Cloud Configuration
# Copy to .env and fill in your values

# --- Xen Orchestra (all XCP-NG ops go through XO) ---
XCPNG_XO_URL=ws://[2a0c:b641:b50:2::70]/api/
XCPNG_XO_TOKEN=                  # Xen Orchestra -> Settings -> Tokens
XCPNG_XO_VERIFY_SSL=false
XCPNG_DEFAULT_SR_UUID=           # `xe sr-list` on your XCP-NG host
XCPNG_DEFAULT_NETWORK_UUID=      # `xe network-list` - your IPv6 network

# Template UUIDs: get with `xe template-list`
# Format: JSON dict {"debian-13": "uuid-here", "openbsd-7.8": "uuid-here"}
XCPNG_TEMPLATES={"debian-13": "", "openbsd-7.8": ""}

# OpenBSD offline root resize builder. Required for OpenBSD customer VMs.
# The builder is a dedicated OpenBSD VM that stays halted except while preparing
# a newly cloned OpenBSD root VDI before first boot.
XCPNG_OPENBSD_BUILDER_VM_UUID=
XCPNG_OPENBSD_BUILDER_SSH_HOST=
XCPNG_OPENBSD_BUILDER_SSH_USER=svag
XCPNG_OPENBSD_BUILDER_SSH_KEY_PATH=/run/secrets/openbsd_builder_ssh_key
XCPNG_OPENBSD_BUILDER_DISK_DEVICE=sd1
XCPNG_OPENBSD_BUILDER_ATTACH_POSITION=1

# --- Openprovider ---
OPENPROVIDER_API_URL=https://api.openprovider.eu/v1beta
OPENPROVIDER_USERNAME=
OPENPROVIDER_PASSWORD=
OPENPROVIDER_OWNER_HANDLE=       # e.g. SR003891-NL
OPENPROVIDER_ADMIN_HANDLE=
OPENPROVIDER_TECH_HANDLE=
OPENPROVIDER_BILLING_HANDLE=
OPENPROVIDER_NAMESERVERS=["ns1.servify.network","ns2.servify.network"]

# --- x402 Payments ---
PAYMENT_RECEIVER_ADDRESS=        # Your wallet address (receives USDC)
PAYMENT_FACILITATOR_URL=https://x402.org/facilitator
PAYMENT_NETWORK=eip155:8453      # Base mainnet
PAYMENT_ASSET=USDC

# Pricing (USD per day)
PAYMENT_PRICE_VM_XS=0.05
PAYMENT_PRICE_VM_SM=0.10
PAYMENT_PRICE_VM_MD=0.20
PAYMENT_PRICE_VM_LG=0.40
PAYMENT_PRICE_VPN=0.02
PAYMENT_PRICE_DOMAIN_MARKUP=1.00

# --- Hyrule General ---
HYRULE_DEPLOY_DOMAIN=deploy.servify.network

# DNS (RFC 2136 dynamic updates)
HYRULE_DNS_SERVER=              # Your authoritative NS IP
HYRULE_DNS_TSIG_KEY=            # Base64 TSIG key
HYRULE_DNS_TSIG_ALGO=hmac-sha256

# VM Lifecycle
HYRULE_VM_GRACE_PERIOD_HOURS=48
HYRULE_MAX_DURATION_DAYS=365
HYRULE_MAX_PORTS=10
HYRULE_BLOCKED_PORTS=[25,465,587]

# Database (Postgres)
HYRULE_DATABASE_URL=postgresql+asyncpg://hyrule:hyrule@localhost/hyrule
